# Loaded automatically via next.config.ts (merged into process.env if unset).
# Prefer `.env.local` for secrets so this file can stay a safe template in git.
#
# Stripe → Developers → API keys: full secret only (sk_test_… or sk_live_…).
#
# Public site URL (no trailing slash) — canonical URLs, Open Graph, sitemap, JSON-LD.
# NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com
#
